# Application Configuration
APP_NAME=Skitec
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True

# Server Configuration
HOST=0.0.0.0
PORT=8000
API_V1_STR=/api/v1
PROJECT_NAME=Skitec

# Database Configuration
DATABASE_URL=postgresql://skitec_user:skitec_password@localhost:5432/skitec_db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=0

# JWT & Security
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173
ALLOWED_CREDENTIALS=True
ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
ALLOWED_HEADERS=*

# External Services (for future integrations)
LOG_LEVEL=INFO
SENTRY_DSN=

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# File Storage
MAX_UPLOAD_SIZE=10485760

# Redis (for caching & async tasks)
REDIS_URL=redis://localhost:6379/0

# Reporting/Analytics
REPORT_RETENTION_DAYS=90
